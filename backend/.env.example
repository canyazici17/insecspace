# Copy this to backend/.env and update values for your environment
# Local MongoDB (no auth)
MONGO_URL="mongodb://localhost:27017"
DB_NAME="insecspace_db"
# Optional: collection name where registrations will be stored
REG_COLLECTION="registrations"
# Frontend origins allowed (comma-separated); set to your frontend host(s)
CORS_ORIGINS="http://localhost:3000"
